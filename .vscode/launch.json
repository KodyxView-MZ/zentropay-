{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "pwa-node",
            "request": "launch",
            "name": "Iniciar Servidor ZentroPay",
            "program": "${workspaceFolder}/server.js",
            "console": "integratedTerminal"
        },
        {
            "type": "chrome",
            "request": "launch",
            "name": "Abrir Checkout (Local)",
            "url": "http://localhost:3000/checkoutip.html",
            "webRoot": "${workspaceFolder}"
        },
        {
            "type": "chrome",
            "request": "launch",
            "name": "Abrir Painel (Local)",
            "url": "http://localhost:3000/infoproductos.html",
            "webRoot": "${workspaceFolder}"
        }
    ]
}