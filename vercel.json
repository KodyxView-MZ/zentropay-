{
  "version": 2,
  "builds": [
    {
      "src": "api/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "*.html",
      "use": "@vercel/static"
    },
    {
      "src": "*.png",
      "use": "@vercel/static"
    },
    {
      "src": "*.jpg",
      "use": "@vercel/static"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    },
    {
      "src": "blackzone/*.html",
      "use": "@vercel/static"
    },
    {
      "src": "zenox-card/*.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/pay",
      "dest": "/api/pay.js"
    },
    {
      "src": "/api/webhook",
      "dest": "/api/webhook.js"
    },
    {
      "src": "/api/check-status/(.*)",
      "dest": "/api/check-status.js?reference=$1"
    },
    {
      "src": "/api/notify-welcome",
      "dest": "/api/notify-welcome.js"
    },
    {
      "src": "/api/notify-withdrawal",
      "dest": "/api/notify-withdrawal.js"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
